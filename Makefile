NAME = push_swap

SRC = 	parsing \
		parsing_2 \
		parsing_3 \
		create_stack \
		main \
		actions \
		actions_doubled \

#OBJECTS = $(SRC:.c=.o)

#INCLUDES    = -I includes -I $(LIBFT_DIR)/includes/

CC = gcc

CFLAGS = -Wall -Werror -Wextra -g3

LIBFT_DIR	= inc/libft/

DIR_SRCS    = src/
DIR_OBJS    = objs/

SRCS        = $(addprefix $(DIR_SRCS), $(addsuffix .c, $(SRC)))
OBJS        = $(addprefix $(DIR_OBJS), $(addsuffix .o, $(SRC)))

all: $(NAME)
#			@$(ECHO) All done

$(NAME): $(OBJS)
		@make -C inc/libft
		@make -C inc/libft bonus
		@$(CC) $(CFLAGS) -o $(NAME) $(OBJS) $(LIBFT_DIR)libft.a
		@echo "All done!"

$(DIR_OBJS)%.o :	$(DIR_SRCS)%.c $(OBJF)
				@mkdir -p $(DIR_OBJS)
				@$(CC) $(CFLAGS) -c $< -o $@
#$(LIBFT):
#			@make -C $(LIBFT_DIR)

clean:
		rm -f $(OBJS)
		make -C inc/libft/ clean
		rm -r $(DIR_OBJS)
		@echo "Cleaning done."

fclean: clean
		rm -f $(NAME)

re: fclean all

.PHONY: all clean fclean re test

